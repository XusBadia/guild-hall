{
	"name": "mission-control",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "npm-run-all --parallel dev:frontend dev:backend dev:auth",
		"dev:frontend": "vite --open",
		"dev:backend": "convex dev",
		"dev:auth": "tsx watch auth-server.ts",
		"predev": "convex dev --until-success && convex dev --once --run-sh \"node setup.mjs --once\" && convex dashboard",
		"build": "tsc -b && vite build",
		"lint": "tsc && eslint .  --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
		"preview": "vite preview",
		"seed": "convex run seed:run",
		"seed:user": "tsx seed-user.ts",
		"format": "biome format --write",
		"check": "biome check ."
	},
	"dependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/utilities": "^3.2.2",
		"@tabler/icons-react": "^3.36.1",
		"@tailwindcss/typography": "^0.5.19",
		"better-auth": "^1.5.4",
		"better-sqlite3": "^12.6.2",
		"convex": "^1.31.7",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-markdown": "^10.1.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.13",
		"@convex-dev/eslint-plugin": "^1.1.1",
		"@eslint/js": "^9.39.2",
		"@tailwindcss/vite": "^4.1.18",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^24.10.9",
		"@types/react": "^19.2.10",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.2",
		"dotenv": "^17.2.3",
		"eslint": "^9.39.2",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.4.26",
		"globals": "^17.2.0",
		"npm-run-all2": "^8.0.4",
		"prettier": "^3.8.1",
		"tailwindcss": "^4.1.18",
		"tsx": "^4.21.0",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1"
	}
}
